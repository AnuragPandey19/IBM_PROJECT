# CHIMERA-FD API environment configuration
# Copy this to .env and edit for your environment
# .env is gitignored — never commit real secrets

# ---- Environment ----
ENV=dev
DEBUG=true

# ---- Server ----
HOST=0.0.0.0
PORT=8000

# ---- Database ----
# Dev default (SQLite): sqlite:///./data/api.db
# Prod: postgresql://user:password@postgres:5432/chimera
DATABASE_URL=sqlite:///./data/api.db

# ---- Redis (velocity feature cache) ----
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# ---- Auth ----
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-in-prod-generate-with-secrets-token-urlsafe-64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ---- CORS (which frontends can call this API) ----
# JSON array format required by pydantic-settings
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ---- Logging ----
LOG_LEVEL=INFO
