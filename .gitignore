# Data — NEVER commit real transaction data
data/raw/*
data/processed/*
data/external/*
data/api.db
data/*.db
data/*.db-journal
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Whitelist ONLY the artifacts needed for serving (HF Space image)
!data/processed/ieee_cis/
data/processed/ieee_cis/*
!data/processed/ieee_cis/feature_pipeline.pkl
!data/processed/ieee_cis/samples.parquet

# Model artifacts — block all files inside models/, whitelist serving ones.
# Note: use "models/*" NOT "models/" — git cannot re-include from an excluded dir.
models/*
*.pkl
*.joblib
*.ckpt
*.pt
*.onnx
!models/stage1_lightgbm.pkl
!models/stage3_isotonic.pkl

# Dev-only reports (large images, arrays)
reports/

# Notebooks — commit clean, not outputs
.ipynb_checkpoints/
# Uncomment next line if you want to strip outputs before commit:
# *.ipynb

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual envs
.venv/
venv/
env/

# Node / Next.js (frontend build artifacts)
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/

# IDEs
.vscode/
.idea/
*.swp
.DS_Store

# Logs
logs/
*.log

# Secrets
.env
.env.local
frontend/.env.local
config/secrets.yaml

# Docker
docker-compose.override.yml

# Reports (bhaari + regenerable)
*.docx
*.pdf
reports/


# Sparkov artifacts needed for backend startup.
# Same pattern as ieee_cis above: whitelist the folder to allow recursion,
# then explicitly BLOCK ALL contents, then whitelist only the file the
# backend actually needs (test_features.parquet drives SparkovLookups).
# Without the block-all-contents line, train_features.parquet (156 MB) and
# val_features.parquet (22 MB) would be committed too, bloating the repo
# and blowing past HF Space LFS bandwidth on rebuilds.
!models/stage1_sparkov.pkl
!data/processed/sparkov/
data/processed/sparkov/*
!data/processed/sparkov/test_features.parquet
